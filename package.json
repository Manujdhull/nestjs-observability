{
  "name": "nestjs-observability",
  "version": "1.0.0",
  "description": "Drop-in observability toolkit for NestJS with correlation IDs, structured logging, Prometheus metrics, and distributed tracing.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "observability",
    "logging",
    "prometheus",
    "metrics",
    "opentelemetry",
    "tracing",
    "correlation-id",
    "pino"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": "^9.0.0 || ^10.0.0 || ^11.0.0",
    "@nestjs/core": "^9.0.0 || ^10.0.0 || ^11.0.0",
    "rxjs": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.8.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.8",
    "rxjs": "^7.8.1",
    "typescript": "^5.4.5"
  }
}
